# SagaCrypto — clean URL rewrites (Fase 9 follow-up).
#
# Written to be portable between local dev (this app may sit in a
# subfolder, e.g. http://localhost/wpm/) and production (app sits at the
# domain root, e.g. https://sagacrypto.com/) WITHOUT needing a different
# RewriteBase per environment: every target below is a relative path
# (no leading slash), so Apache resolves it relative to the directory this
# .htaccess lives in — whatever that directory is mounted as.
#
# All existing *.php files keep working directly with their original
# ?slug=/?tag=/?mode= query strings (nothing here breaks old links); this
# just adds pretty aliases on top and is what all internal links now point
# to (see includes/site-bootstrap.php, index.php, artikel.php, kategori.php,
# pencarian.php).
#
# Requires mod_rewrite enabled and AllowOverride All (or at least
# "AllowOverride FileInfo") on the directory — ask your hosting/Docker
# Apache config if these rules don't seem to take effect.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Never rewrite requests that already point at a real file or directory
    # (assets/, cms-admin/, uploads/, the *.php files themselves, etc.).
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # /artikel/<slug> -> artikel.php?slug=<slug>
    RewriteRule ^artikel/([^/]+)/?$ artikel.php?slug=$1 [L,QSA]

    # /tag/<slug> -> kategori.php?tag=<slug>
    RewriteRule ^tag/([^/]+)/?$ kategori.php?tag=$1 [L,QSA]

    # /kategori/<slug> -> kategori.php?slug=<slug>  (category listing)
    RewriteRule ^kategori/([^/]+)/?$ kategori.php?slug=$1 [L,QSA]

    # /kategori -> kategori.php  (all articles)
    RewriteRule ^kategori/?$ kategori.php [L,QSA]

    # /crypto -> crypto.php
    RewriteRule ^crypto/?$ crypto.php [L,QSA]

    # /pencarian -> pencarian.php  (search form still submits ?q=... via QSA)
    RewriteRule ^pencarian/?$ pencarian.php [L,QSA]

    # Sitemaps module (14 Jul 2026) — /sitemap.xml and /sitemap-index.xml
    # both serve the same sitemap index; the four per-type files are the
    # sub-sitemaps it points search engines at. See sitemap.php.
    RewriteRule ^sitemap\.xml$ sitemap.php?type=index [L,QSA]
    RewriteRule ^sitemap-index\.xml$ sitemap.php?type=index [L,QSA]
    RewriteRule ^sitemap-pages\.xml$ sitemap.php?type=pages [L,QSA]
    RewriteRule ^sitemap-articles\.xml$ sitemap.php?type=articles [L,QSA]
    RewriteRule ^sitemap-categories\.xml$ sitemap.php?type=categories [L,QSA]
    RewriteRule ^sitemap-custom\.xml$ sitemap.php?type=custom [L,QSA]
</IfModule>
